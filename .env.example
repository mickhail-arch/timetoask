# App
APP_URL=http://localhost:3000
APP_NAME=MarketingAI
NODE_ENV=development
 
# Database (Prisma 7 + adapter)
DATABASE_URL=postgresql://user:pass@localhost:5432/wrapper
DATABASE_URL_TEST=postgresql://user:pass@localhost:5432/wrapper_test
PG_POOL_MAX=10  # prod: 50
PG_USER=wrapper           # used by docker-compose.prod.yml
PG_PASSWORD=              # used by docker-compose.prod.yml
PG_DB=wrapper             # used by docker-compose.prod.yml
 
# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=  # обязателен в production
 
# LLM
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_MODEL=openrouter/auto
 
# Auth
NEXTAUTH_SECRET=  # min 32 символа
NEXTAUTH_URL=http://localhost:3000
 
# Payments (ЮKassa)
YOKASSA_SHOP_ID=
YOKASSA_SECRET_KEY=
YOKASSA_WEBHOOK_SECRET=
YOKASSA_RETURN_URL=http://localhost:3000/billing
 
# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
 
# Monitoring
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
 
# Concurrency
MAX_CONCURRENT_GLOBAL=20
MAX_CONCURRENT_PER_USER=2
MAX_CONCURRENT_ASYNC=5
MAX_EXECUTION_TIMEOUT_MS=120000
 
# Billing defaults
TOOL_TOKEN_COST=100
FREE_TOKENS_ON_REGISTER=300
RATE_LIMIT_PER_MINUTE=60
 
# Search (для async инструментов)
SERPER_API_KEY=
SERPAPI_KEY=  # fallback
 
# Admin seed (только для prisma db seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
