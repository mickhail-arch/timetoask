# ROUTE HANDLER — ШАБЛОН (копировать)
# ══════════════════════════════════════
export async function POST(req: Request) {
  const session = await getServerSession(authOptions);
  if (!session) return NextResponse.json(
    { error: { code: 'UNAUTHORIZED', statusCode: 401 } }, { status: 401 }
  );
  const body = schema.parse(await req.json());
  const result = await Service.method(session.user.id, body);
  return NextResponse.json({ data: result });
}

# ══════════════════════════════════════
# MIDDLEWARE — ТОЛЬКО ЭТО
# ══════════════════════════════════════
export default function middleware(request: NextRequest) {
  const token = request.cookies.get('next-auth.session-token');
  if (request.nextUrl.pathname.startsWith('/dashboard') && !token) {
    return NextResponse.redirect(new URL('/login', request.url));
  }
  return NextResponse.next();
}
Никакого Prisma, Redis, бизнес-логики в middleware.ts.

